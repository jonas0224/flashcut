# Upstash Redis (optional for local dev — uses in-memory store if unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel KV integration (alternative names — set automatically on Vercel)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Team gate — set in production so only your team can use the app
ROOM_PASSWORD=

# Vercel Blob — required for custom round image uploads in production
BLOB_READ_WRITE_TOKEN=
